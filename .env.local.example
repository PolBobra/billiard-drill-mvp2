# Скопируй этот файл в .env.local и вставь свои значения из Supabase:
# Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Только для серверных /api/admin/* маршрутов (страница модерации).
# Project Settings -> API -> service_role secret. НЕ добавлять префикс NEXT_PUBLIC_ —
# это секретный ключ с полным доступом, он не должен попасть в браузер.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare Turnstile: NEXT_PUBLIC_TURNSTILE_SITE_KEY уже используется на
# login/register (виден в браузере). TURNSTILE_SECRET_KEY — новый, только
# для сервера: /api/trainer/link проверяет капчу напрямую через Cloudflare
# siteverify (в отличие от логина/регистрации, где капчу проверяет сам
# Supabase Auth). Взять в Cloudflare Dashboard -> Turnstile -> тот же сайт.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Claude API — подбор упражнения под зафиксированную на столе ошибку
# (/api/match-exercise). Взять на console.anthropic.com -> API Keys.
# Без этого ключа фича не ломается — молча откатывается на подбор без ИИ
# по формальным критериям (см. fallbackMatch в app/api/match-exercise/route.ts).
ANTHROPIC_API_KEY=your-anthropic-api-key
