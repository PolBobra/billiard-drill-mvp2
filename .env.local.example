# Скопируй этот файл в .env.local и вставь свои значения из Supabase:
# Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Только для серверных /api/admin/* маршрутов (страница модерации).
# Project Settings -> API -> service_role secret. НЕ добавлять префикс NEXT_PUBLIC_ —
# это секретный ключ с полным доступом, он не должен попасть в браузер.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Yandex SmartCaptcha — заменили Cloudflare Turnstile (его домен
# challenges.cloudflare.com плохо доступен в РФ без VPN). Капчу теперь
# проверяем сами на сервере (lib/yandexCaptcha.ts) для входа/регистрации
# (app/api/auth/login, app/api/auth/register) и привязки к тренеру
# (app/api/trainer/link) — встроенная капча Supabase Auth должна быть
# ВЫКЛЮЧЕНА в дашборде (Authentication -> Settings), иначе Supabase будет
# ждать Turnstile-токен, которого больше нет.
# Ключи — в Yandex Cloud Console -> SmartCaptcha -> создать капчу для сайта.
NEXT_PUBLIC_YANDEX_CAPTCHA_SITE_KEY=your-yandex-captcha-client-key
YANDEX_CAPTCHA_SERVER_KEY=your-yandex-captcha-server-key

# Claude API — подбор упражнения под зафиксированную на столе ошибку
# (/api/match-exercise). Взять на console.anthropic.com -> API Keys.
# Без этого ключа фича не ломается — молча откатывается на подбор без ИИ
# по формальным критериям (см. fallbackMatch в app/api/match-exercise/route.ts).
ANTHROPIC_API_KEY=your-anthropic-api-key

# Telegram-уведомления админу о новых заявках (клубы/тренеры-справочник,
# верификация/правка резюме тренера). Без этих двух переменных просто
# молча ничего не отправляется, заявки продолжают сохраняться как обычно.
# TELEGRAM_BOT_TOKEN — у @BotFather -> /mybots -> твой бот -> API Token.
# TELEGRAM_CHAT_ID — напиши боту любое сообщение, затем открой в браузере
# https://api.telegram.org/bot<TOKEN>/getUpdates и найди "chat":{"id": ...}.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Секрет вебхука бота-поддержки (/api/telegram-webhook) — Telegram шлёт его
# в заголовке X-Telegram-Bot-Api-Secret-Token при каждом входящем сообщении,
# так роут отличает реальный Telegram от случайного запроса. Любая длинная
# случайная строка, задаётся один раз при вызове setWebhook.
TELEGRAM_WEBHOOK_SECRET=your-random-webhook-secret
